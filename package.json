{
  "name": "back",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:middlewares": "jest tests/unit/middlewares",
    "test:controllers": "jest tests/unit/controllers",
    "test:utils": "jest tests/unit/utils",
    "test:services": "jest tests/unit/services",
    "test:mpclient": "jest tests/unit/integrations/mpClient.test.js",
    "test:shared": "jest tests/unit/shared",
    "test:repos": "jest tests/unit/repos",
    "build": "tsc",
    "dev": "nodemon src/server.js",
    "dev-ts": "tsc-watch --onSuccess \"node dist/server.js\"",
    "start": "node src/server.js",
    "start-ts": "node dist/server.js"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mercadopago": "^2.11.0",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.9.3"
  }
}
